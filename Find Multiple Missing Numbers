const arr = [5, 3, 1, 2, 6];

function findMissing(arr) {
  arr.sort((a, b) => a - b);

  for (let i = 0; i < arr.length; i++) {
    if (arr[i] !== i + 1) {
      return i + 1;
    }
  }

  return arr.length + 1;
}

