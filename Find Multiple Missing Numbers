const arr = [1, 2, 4, 6, 7, 10];

function findMissingNumbers(arr) {
  let missing = [];
  let max = Math.max(...arr);

  for (let i = 1; i <= max; i++) {
    if (!arr.includes(i)) {
      missing.push(i);
    }
  }

  return missing;
}

console.log(findMissingNumbers(arr));

